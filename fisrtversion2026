      section.id = `section-art-${art.id}`;
      section.dataset.index = index + 2;
      section.style.background = `linear-gradient(135deg, ${art.color} 0%, ${adjustColor(art.color, -20)} 100%)`;
      section.style.color = art.textColor;
      
      const isEven = index % 2 === 0;
      
      section.innerHTML = `
