      const heights = ['h-32', 'h-40', 'h-36', 'h-44', 'h-32'];
      const height = heights[index % heights.length];
      
      building.innerHTML = `
        <div class="relative">
          <svg class="${height} w-20 md:w-24" viewBox="0 0 80 120" fill="none">
            <!-- Roof -->
            <polygon points="10,40 40,10 70,40" fill="${art.color}" />
            <!-- Body -->
            <rect x="15" y="40" width="50" height="70" fill="${art.color}" opacity="0.9"/>
            <!-- Door -->
            <rect x="33" y="80" width="14" height="30" fill="${art.textColor}" opacity="0.3" rx="2"/>
