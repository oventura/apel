    if (titleParts.length >= 3) {
      const half = Math.ceil(titleParts.length / 2);
      document.getElementById('hero-title').innerHTML = 
        titleParts.slice(0, half).join(' ') + '<br>' + titleParts.slice(half).join(' ');
    } else {
      document.getElementById('hero-title').textContent = title;
    }
    
    document.getElementById('hero-subtitle').textContent = config.event_subtitle || defaultConfig.event_subtitle;
    document.getElementById('hero-date').textContent = config.event_date || defaultConfig.event_date;
    document.getElementById('hero-school').textContent = config.school_name || defaultConfig.school_name;
    document.getElementById('footer-slogan').textContent = config.footer_slogan || defaultConfig.footer_slogan;
    document.getElementById('footer-date').textContent = config.event_date || defaultConfig.event_date;
    document.getElementById('footer-location').textContent = config.event_location || defaultConfig.event_location;
    document.getElementById('footer-school').textContent = config.school_name || defaultConfig.school_name;
  }

  function mapToCapabilities(config) {
    return {
      recolorables: [],
      borderables: [],
      fontEditable: undefined,
      fontSizeable: undefined
    };
  }

  function mapToEditPanelValues(config) {
    return new Map([
      ["school_name", config.school_name || defaultConfig.school_name],
      ["event_title", config.event_title || defaultConfig.event_title],
      ["event_subtitle", config.event_subtitle || defaultConfig.event_subtitle],
      ["event_date", config.event_date || defaultConfig.event_date],
      ["event_location", config.event_location || defaultConfig.event_location],
      ["footer_slogan", config.footer_slogan || defaultConfig.footer_slogan],
      ["contact_phone", config.contact_phone || defaultConfig.contact_phone],
      ["contact_email", config.contact_email || defaultConfig.contact_email]
    ]);
  }

  // Initialize
  init();
  
  if (window.elementSdk) {
    window.elementSdk.init({
      defaultConfig,
      onConfigChange,
      mapToCapabilities,
      mapToEditPanelValues
    });
  }
