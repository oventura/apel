  // Create confetti
  function createConfetti() {
    const container = document.getElementById('confetti-container');
    const colors = ['#7FC4B5', '#F28C4A', '#E87FA6', '#F4C542', '#8B6BB0', '#3B8A94', '#D65A5A'];
    const shapes = ['', 'border-radius: 50%;', 'transform: rotate(45deg);'];
    
    for (let i = 0; i < 40; i++) {
      const confetti = document.createElement('div');
      confetti.className = 'confetti';
      const color = colors[Math.floor(Math.random() * colors.length)];
      const shape = shapes[Math.floor(Math.random() * shapes.length)];
      confetti.style.cssText = `
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        background: ${color};
        animation-delay: ${Math.random() * 6}s;
        animation-duration: ${4 + Math.random() * 4}s;
        ${shape}
      `;
      container.appendChild(confetti);
    }
  }

  // Create city buildings
  function createCity() {
    const grid = document.getElementById('city-grid');
    artSections.forEach((art, index) => {
      const building = document.createElement('div');
      building.className = 'building flex flex-col items-center';
      building.onclick = () => {
        document.getElementById(`section-art-${art.id}`).scrollIntoView({ behavior: 'smooth' });
