            <p class="text-lg md:text-xl mb-8 reveal reveal-delay-2 max-w-lg" style="color: ${art.textColor}; opacity: 0.95;">
              ${art.description}
            </p>
            <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full reveal reveal-delay-3" style="background: ${art.textColor}; color: ${art.color};">
              <i data-lucide="sparkles" class="w-5 h-5"></i>
              <span class="font-bold">${art.activity}</span>
            </div>
            
            <!-- Stats -->
            <div class="mt-8 flex gap-6 reveal reveal-delay-3">
              <div>
                <p class="font-display text-3xl md:text-4xl" style="color: ${art.textColor};">#${String(index + 1).padStart(2, '0')}</p>
                <p class="text-sm opacity-80">Maison</p>
              </div>
              <div class="w-px opacity-30" style="background: ${art.textColor};"></div>
