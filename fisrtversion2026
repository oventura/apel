  <style>
  :root {
    --cream: #FDF6E8;
    --mint: #7FC4B5;
    --orange: #F28C4A;
    --pink: #E87FA6;
    --yellow: #F4C542;
    --purple: #8B6BB0;
    --teal: #3B8A94;
    --navy: #2B4C6F;
    --red: #D65A5A;
    --sage: #A8C97A;
  }
  
  html, body {
    height: 100%;
    width: 100%;
    margin: 0;
    padding: 0;
  }
  
  body {
    font-family: 'Fredoka', sans-serif;
    background: var(--cream);
    color: var(--navy);
    overflow-x: hidden;
  }
  
  .font-display { font-family: 'Montserrat', sans-serif; font-weight: 900; }
  .font-script { font-family: 'Pacifico', cursive; }
  .font-body { font-family: 'Fredoka', sans-serif; }
  
  .scroll-container {
    height: 100%;
    overflow-y: auto;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }
  
  .snap-section {
    scroll-snap-align: start;
    min-height: 100%;
    width: 100%;
    position: relative;
    overflow: hidden;
  }
  
  @media (max-width: 768px) {
    .scroll-container { scroll-snap-type: y proximity; }
  }
  
  /* Confetti animation */
  .confetti {
    position: absolute;
    width: 12px;
    height: 12px;
    opacity: 0.9;
    animation: float 6s ease-in-out infinite;
    pointer-events: none;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(180deg); }
  }
  
  /* Flags */
  .flag {
    display: inline-block;
    width: 28px;
    height: 36px;
    margin: 0 2px;
    clip-path: polygon(0 0, 100% 0, 100% 75%, 50% 100%, 0 75%);
    animation: sway 3s ease-in-out infinite;
    transform-origin: top center;
  }
  
  @keyframes sway {
    0%, 100% { transform: rotate(-3deg); }
    50% { transform: rotate(3deg); }
  }
  
  .flag-string {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 20px;
  }
  
  .flag-string::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 5%;
    right: 5%;
    height: 2px;
    background: var(--navy);
    border-radius: 2px;
  }
  
  /* Building hover effects */
  .building {
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
    position: relative;
  }
  
  .building:hover {
    transform: translateY(-12px) scale(1.05);
    filter: drop-shadow(0 20px 25px rgba(0,0,0,0.15));
  }
  
  .building-label {
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
    position: absolute;
    bottom: -35px;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    white-space: nowrap;
    pointer-events: none;
  }
  
  .building:hover .building-label {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  
  /* Section reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
  
  .reveal-delay-1 { transition-delay: 0.15s; }
  .reveal-delay-2 { transition-delay: 0.3s; }
  .reveal-delay-3 { transition-delay: 0.45s; }
  
  /* Floating animation for icons */
  @keyframes floatIcon {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-15px) rotate(2deg); }
  }
  
  .float-icon {
    animation: floatIcon 4s ease-in-out infinite;
  }
  
  /* Placeholder style */
  .photo-placeholder {
    background: rgba(255,255,255,0.15);
    border: 3px dashed rgba(255,255,255,0.5);
    backdrop-filter: blur(4px);
    transition: all 0.3s ease;
  }
  
  .photo-placeholder:hover {
    background: rgba(255,255,255,0.25);
    border-color: rgba(255,255,255,0.8);
  }
  
  /* Cloud decoration */
  .cloud {
    position: absolute;
    opacity: 0.4;
    animation: drift 20s linear infinite;
  }
  
  @keyframes drift {
    from { transform: translateX(-100px); }
    to { transform: translateX(calc(100vw + 100px)); }
  }
  
  /* Progress indicator */
  .progress-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(43, 76, 111, 0.3);
    transition: all 0.3s ease;
    cursor: pointer;
    display: block;
    margin: 8px 0;
  }
  
  .progress-dot.active {
    background: var(--navy);
    transform: scale(1.5);
  }
  
  .progress-dot:hover {
    background: var(--navy);
  }
  
  /* Button styles */
  .btn-primary {
    background: var(--navy);
    color: var(--cream);
    padding: 14px 32px;
    border-radius: 50px;
    font-weight: 700;
    transition: all 0.3s ease;
    box-shadow: 0 6px 0 rgba(0,0,0,0.2);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 0 rgba(0,0,0,0.2);
  }
  
  .btn-primary:active {
    transform: translateY(4px);
    box-shadow: 0 2px 0 rgba(0,0,0,0.2);
  }
  
  /* Scroll indicator */
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(10px); }
  }
  
  .scroll-indicator {
    animation: bounce-slow 2s ease-in-out infinite;
  }
  
  /* Sun rays for hero */
  @keyframes rotate-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  .sun-rays {
    animation: rotate-slow 30s linear infinite;
  }
  
  /* Grass decoration */
  .grass {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 60px;
    background: linear-gradient(to top, var(--sage) 0%, transparent 100%);
    opacity: 0.4;
  }
  
  /* Responsive text */
  .text-hero {
    font-size: clamp(2.5rem, 8vw, 6rem);
    line-height: 1;
  }
  
  .text-section-title {
    font-size: clamp(2rem, 6vw, 4.5rem);
    line-height: 1.1;
  }
</style>
